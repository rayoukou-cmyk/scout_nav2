<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="scout_mini_test_world">

    <!-- Physics -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin
      filename="ignition-gazebo-physics-system"
      name="ignition::gazebo::systems::Physics">
    </plugin>
    <plugin
      filename="ignition-gazebo-scene-broadcaster-system"
      name="ignition::gazebo::systems::SceneBroadcaster">
    </plugin>
    <plugin
      filename="ignition-gazebo-contact-system"
      name="ignition::gazebo::systems::Contact">
    </plugin>
    <plugin
      filename="ignition-gazebo-imu-system"
      name="ignition::gazebo::systems::Imu">
    </plugin>

    <!-- Lighting -->
    <scene>
      <ambient>0.4 0.4 0.4 1.0</ambient>
      <background>0.7 0.7 0.7 1.0</background>
      <shadows>true</shadows>
    </scene>

    <!-- Sun -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1.0</diffuse>
      <specular>0.2 0.2 0.2 1.0</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground Plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1.0</ambient>
            <diffuse>0.8 0.8 0.8 1.0</diffuse>
            <specular>0.1 0.1 0.1 1.0</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== WALLS (Navigation Arena) ==================== -->
    <!-- Outer walls: 10m x 10m arena -->
    <xmacro_define name="wall_thickness" value="0.2"/>
    <xmacro_define name="wall_height" value="1.0"/>
    <xmacro_define name="arena_size" value="10.0"/>

    <!-- North Wall -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 5.1 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>10.4 0.2 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>10.4 0.2 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.6 0.3 0.3 1.0</ambient>
            <diffuse>0.6 0.3 0.3 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- South Wall -->
    <model name="wall_south">
      <static>true</static>
      <pose>0 -5.1 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>10.4 0.2 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>10.4 0.2 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.6 0.3 0.3 1.0</ambient>
            <diffuse>0.6 0.3 0.3 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- East Wall -->
    <model name="wall_east">
      <static>true</static>
      <pose>5.1 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.2 10.4 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.2 10.4 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.6 0.3 0.3 1.0</ambient>
            <diffuse>0.6 0.3 0.3 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- West Wall -->
    <model name="wall_west">
      <static>true</static>
      <pose>-5.1 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.2 10.4 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.2 10.4 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.6 0.3 0.3 1.0</ambient>
            <diffuse>0.6 0.3 0.3 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== INNER OBSTACLES ==================== -->
    <!-- Obstacle 1: Central pillar -->
    <model name="obstacle_center">
      <static>true</static>
      <pose>0 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.6 0.6 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.6 0.6 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.3 0.5 0.3 1.0</ambient>
            <diffuse>0.3 0.5 0.3 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle 2: Left corridor wall -->
    <model name="obstacle_left">
      <static>true</static>
      <pose>-2.0 2.0 0.5 0 0 0.785</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>1.5 0.2 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>1.5 0.2 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.6 1.0</ambient>
            <diffuse>0.3 0.3 0.6 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle 3: Right corridor wall -->
    <model name="obstacle_right">
      <static>true</static>
      <pose>2.0 -2.0 0.5 0 0 -0.785</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>1.5 0.2 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>1.5 0.2 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.6 1.0</ambient>
            <diffuse>0.3 0.3 0.6 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle 4: Small box near goal area -->
    <model name="obstacle_box">
      <static>true</static>
      <pose>3.0 3.0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.5 0.5 0.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.5 0.5 0.5</size></box>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.2 1.0</ambient>
            <diffuse>0.6 0.6 0.2 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Goal marker (visual only, no collision) -->
    <model name="goal_marker">
      <static>true</static>
      <pose>4.0 4.0 0.01 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <cylinder><radius>0.3</radius><length>0.02</length></cylinder>
          </geometry>
          <material>
            <ambient>0.0 1.0 0.0 0.5</ambient>
            <diffuse>0.0 1.0 0.0 0.5</diffuse>
            <transparency>0.5</transparency>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
