<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="scout_mini">

  <!-- ==================== PROPERTIES ==================== -->
  <xacro:property name="PI" value="3.1415926535897931"/>

  <!-- Scout Mini Dimensions (approximate from AgileX specs) -->
  <xacro:property name="base_length" value="0.627"/>
  <xacro:property name="base_width" value="0.550"/>
  <xacro:property name="base_height" value="0.252"/>
  <xacro:property name="base_z_offset" value="0.126"/>
  <xacro:property name="wheel_radius" value="0.0825"/>
  <xacro:property name="wheel_width" value="0.075"/>
  <xacro:property name="wheel_separation" value="0.406"/>
  <xacro:property name="wheel_y_offset" value="0.203"/>
  <xacro:property name="wheel_x_offset" value="0.0"/>

  <!-- LiDAR properties -->
  <xacro:property name="lidar_mass" value="0.3"/>
  <xacro:property name="lidar_radius" value="0.04"/>
  <xacro:property name="lidar_height" value="0.06"/>

  <!-- Front LiDAR position (from scout_lidar reference) -->
  <xacro:property name="front_lidar_x" value="0.5"/>
  <xacro:property name="front_lidar_y" value="0.0"/>
  <xacro:property name="front_lidar_z" value="0.25"/>
  <xacro:property name="front_lidar_yaw" value="0.0"/>

  <!-- Rear LiDAR position (from scout_lidar reference) -->
  <xacro:property name="rear_lidar_x" value="-0.5"/>
  <xacro:property name="rear_lidar_y" value="0.0"/>
  <xacro:property name="rear_lidar_z" value="0.25"/>
  <xacro:property name="rear_lidar_yaw" value="3.1416"/>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0 0.0 ${base_z_offset}" rpy="0 0 0"/>
      <mass value="20.0"/>
      <inertia ixx="0.35" ixy="0.0" ixz="0.0"
               iyy="0.55" iyz="0.0"
               izz="0.65"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 ${base_z_offset}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="scout_body">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 ${base_z_offset}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- ==================== WHEELS ==================== -->
  <xacro:macro name="wheel" params="prefix x y side">
    <link name="${prefix}_wheel_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1.5"/>
        <inertia ixx="0.005" ixy="0.0" ixz="0.0"
                 iyy="0.008" iyz="0.0"
                 izz="0.005"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${x} ${y} ${wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="front_left"  x="${wheel_x_offset}"  y="${wheel_y_offset}"  side="left"/>
  <xacro:wheel prefix="front_right" x="${wheel_x_offset}"  y="-${wheel_y_offset}" side="right"/>
  <xacro:wheel prefix="rear_left"   x="-${wheel_x_offset}" y="${wheel_y_offset}"  side="left"/>
  <xacro:wheel prefix="rear_right"  x="-${wheel_x_offset}" y="-${wheel_y_offset}" side="right"/>

  <!-- ==================== FRONT LIDAR ==================== -->
  <link name="front_lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${lidar_mass}"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="lidar">
        <color rgba="0.8 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_lidar_link"/>
    <origin xyz="${front_lidar_x} ${front_lidar_y} ${front_lidar_z}" 
            rpy="0 0 ${front_lidar_yaw}"/>
  </joint>

  <!-- ==================== REAR LIDAR ==================== -->
  <link name="rear_lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${lidar_mass}"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="lidar_rear">
        <color rgba="0.1 0.1 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
  </link>

  <joint name="rear_lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_lidar_link"/>
    <origin xyz="${rear_lidar_x} ${rear_lidar_y} ${rear_lidar_z}" 
            rpy="0 0 ${rear_lidar_yaw}"/>
  </joint>

  <!-- ==================== IMU LINK ==================== -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- ==================== GAZEBO PLUGINS (Ignition Fortress) ==================== -->
  <!-- Differential Drive Plugin -->
  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation * 2}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <velocity_iterations>10</velocity_iterations>
      <position_iterations>10</position_iterations>
    </plugin>
  </gazebo>

  <!-- IMU Plugin -->
  <gazebo reference="imu_link">
    <plugin filename="ignition-gazebo-imu-system" name="ignition::gazebo::systems::Imu">
      <topic>imu</topic>
    </plugin>
  </gazebo>

  <!-- Front LiDAR Sensor (Ignition Fortress GPU Lidar) -->
  <gazebo reference="front_lidar_link">
    <sensor name="front_lidar_sensor" type="gpu_lidar">
      <update_rate>10</update_rate>
      <topic>front_lidar_scan</topic>
      <gz_frame_id>front_lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.2</min>
          <max>50.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- Rear LiDAR Sensor (Ignition Fortress GPU Lidar) -->
  <gazebo reference="rear_lidar_link">
    <sensor name="rear_lidar_sensor" type="gpu_lidar">
      <update_rate>10</update_rate>
      <topic>rear_lidar_scan</topic>
      <gz_frame_id>rear_lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.2</min>
          <max>50.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- Contact Sensor for stability -->
  <gazebo reference="base_link">
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
    <self_collide>false</self_collide>
  </gazebo>

  <gazebo reference="front_left_wheel_link">
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
  </gazebo>
  <gazebo reference="front_right_wheel_link">
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
  </gazebo>
  <gazebo reference="rear_left_wheel_link">
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
  </gazebo>
  <gazebo reference="rear_right_wheel_link">
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
  </gazebo>

</robot>
